    {
        "id": "function_sql",
        "type": "function",
        "z": "d4ee9751039cadd3",
        "name": "Montar SQL",
        "func": "let data = msg.payload;\n\nif(!data.lat || !data.lon){\n node.warn(\"Mensagem inválida recebida\");\n return null;\n}\n\n// cria data do evento\nlet agora = new Date();\n\n// guarda dados para usar depois\nmsg.gps = {\n    id: \"ESP32\",\n    lat: data.lat,\n    lon: data.lon,\n    evento: data.evento,\n    data_evento: agora\n};\n\n// envia também para o banco\nmsg.topic = \"INSERT INTO eventos (dispositivo, latitude, longitude, evento, data_evento) VALUES ('ESP32',\" \n + data.lat + \",\" + data.lon + \",'\" + data.evento + \"','\" + agora.toISOString().slice(0,19).replace('T',' ') + \"')\";\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 160,
        "wires": [
            [
                "mysql_db"
            ]
        ]
    },
