        "name": "Monta tabela",
        "func": "let row = msg.gps;\n\n// pega o id que o banco criou\nlet idBanco = msg.payload.insertId;\n\nmsg.payload = {\n    id: idBanco,\n    lat: row.lat,\n    lon: row.lon,\n    evento: row.evento,\n    tempo: new Date(row.data_evento).toLocaleString(\"pt-BR\")\n};\n\nreturn msg;\n",
