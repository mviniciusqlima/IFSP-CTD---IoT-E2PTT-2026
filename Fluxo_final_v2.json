    {
        "id": "94c91dd088f5054e",
        "type": "function",
        "z": "d4ee9751039cadd3",
        "name": "Calcula porc. eventos",
        "func": "let evento = msg.payload.evento;\n\nlet manual = flow.get(\"manual\") || 0;\nlet obstaculo = flow.get(\"obstaculo\") || 0;\n\nif(evento === \"manual\"){\n    manual++;\n}\n\nif(evento === \"obstaculo\"){\n    obstaculo++;\n}\n\nflow.set(\"manual\", manual);\nflow.set(\"obstaculo\", obstaculo);\n\nlet total = manual + obstaculo;\n\nlet percManual = total ? (manual/total*100).toFixed(2) : 0;\nlet percObst = total ? (obstaculo/total*100).toFixed(2) : 0;\n\nmsg.payload = [\n    {evento:\"Manual\", valor: percManual},\n    {evento:\"Obstáculo\", valor: percObst}\n];\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 340,
        "wires": [
