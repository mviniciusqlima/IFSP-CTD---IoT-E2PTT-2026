    {
        "id": "confirmar_limpeza",
        "type": "function",
        "z": "d4ee9751039cadd3",
        "name": "SQL Limpar",
        "func": "// 1️⃣ limpa o banco\nlet limparBD = {\n    topic: \"TRUNCATE TABLE eventos\"\n};\n\n// 2️⃣ limpa todos os marcadores do mapa (worldmap)\nlet limparMapa = {\n    payload: {\n        command: \"clear\"\n    }\n};\n\n// 3️⃣ zera os contadores do gráfico\nflow.set(\"manual\",0);\nflow.set(\"obstaculo\",0);\n\n// envia gráfico vazio\nlet limparGrafico = {\n    payload: [\n        {evento:\"Manual\", valor:0},\n        {evento:\"Obstáculo\", valor:0}\n    ]\n};\n\n// 4️⃣ envia comando para atualizar página\nlet atualizarPagina = {\n    payload: {\n        refresh: true\n    }\n};\n\nflow.set(\"totalEventos\",0);\n\nlet limparContador = {\n    payload: 0\n};\n\n\nreturn [limparBD, limparMapa, limparGrafico, atualizarPagina, limparContador];\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
