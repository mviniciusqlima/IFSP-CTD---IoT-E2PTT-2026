    {
        "id": "a9d4e4f543ae69df",
        "type": "function",
        "z": "d4ee9751039cadd3",
        "name": "Monta mapa",
        "func": "let row = msg.gps;\n\n// pega último ponto salvo\nlet ultimo = flow.get(\"ultimoPonto\");\n\n// se existir último ponto, manda ele como histórico\nif (ultimo) {\n    node.send({\n        payload: {\n            name: \"hist_\" + Date(),\n            lat: ultimo.lat,\n            lon: ultimo.lon,\n            layer: \"Histórico\",\n            icon: \"circle\",\n            iconColor: \"yellow\",\n            popup: \"Ponto mapeado\"\n        }\n    });\n}\n\n// salva novo ponto como último\nflow.set(\"ultimoPonto\", row);\n\n// envia ponto atual destacado\nmsg.payload = {\n    name: \"ESP32\",\n    lat: row.lat,\n    lon: row.lon,\n    layer: \"GPS\",\n    icon: \"circle\",\n    iconColor: \"red\",\n    popup: \"Último evento: \" + row.evento\n};\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 610,
        "y": 160,
        "wires": [
            [
                "6a6c00fc3a79acf5",
                "debug_sql"
            ]
        ]
    },
